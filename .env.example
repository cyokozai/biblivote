# ================================================================
# Biblivote 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を記入してください
#   cp .env.example .env
# ================================================================

# ----------------------------------------------------------------
# フロントエンド設定（scripts/inject-env.js で index.html へ注入）
# ----------------------------------------------------------------

# GAS Web App URL
# clasp deploy 後に「ウェブアプリ URL」として表示される
# 例: https://script.google.com/macros/s/AKfy.../exec
GAS_ENDPOINT=

# Grafana ダッシュボード URL（TBD-003 確定後に設定）
# 例: https://grafana.example.com/d/biblivote
GRAFANA_URL=

# reCAPTCHA v3 サイトキー（フロントエンド用・公開可）
# Google reCAPTCHA Admin Console: https://www.google.com/recaptcha/admin
# サイトタイプ: スコアベース (v3)
RECAPTCHA_SITE_KEY=

# Google Books API キー（省略可: 未設定時はキーなしで呼び出し）
# GCP Console > APIs & Services > Credentials で取得
# 有効にする API: Books API
GOOGLE_BOOKS_API_KEY=

# ----------------------------------------------------------------
# GAS スクリプトプロパティ（GAS エディタで設定・ここへの記載は任意）
# GAS スクリプトエディタ > プロジェクトの設定 > スクリプトプロパティ
# ----------------------------------------------------------------

# SPREADSHEET_ID=your_spreadsheet_id
# RECAPTCHA_SECRET=your_recaptcha_v3_secret_key
