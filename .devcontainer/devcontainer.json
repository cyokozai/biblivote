{
  "name": "Biblivote Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "target": "dev"
  },
  "workspaceFolder": "/workspace",
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
    "source=biblivote_node_modules,target=/workspace/node_modules,type=volume",
    // clasp OAuth トークン（ホストで clasp login 済みの場合のみ有効）
    // 値は表示・編集しないこと。認証が必要な場合はホストで clasp login を実行する。
    "source=${localEnv:HOME}/.clasprc.json,target=/root/.clasprc.json,type=bind,readonly"
  ],
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Static Server",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "npm install",
  "remoteUser": "root",
  "customizations": {
    "vscode": {
      "extensions": [
        // Claude Code
        "anthropics.claude-code",
        // テスト
        "orta.vscode-jest",
        "ms-playwright.playwright",
        // コード品質
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        // HTML / CSS / JS
        "ecmel.vscode-html-css",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        // Git
        "eamodio.gitlens"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "jest.autoRun": "watch",
        // Alpine.js の x-* 属性をHTMLバリデーションエラーから除外
        "html.customData": [],
        "css.lint.unknownAtRules": "ignore"
      }
    }
  }
}
